<div class="modal fade" id="createLinkModal" tabindex="-1" role="dialog" aria-labelledby="createLinkModalLabel" x-data="linkApp">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" @click="closeModal" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                <h4 class="modal-title" id="createLinkModalLabel">Link Oluştur</h4>
            </div>
            <div class="modal-body">
                <div x-show="errorMessage" class="alert alert-danger" x-text="errorMessage"></div>
                <div x-show="generatedLink" class="alert alert-success">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="flex-grow-1">
                            <strong>Link oluşturuldu:</strong>
                            <div class="mt-2">
                                <a :href="generatedLink" target="_blank" class="text-break">Tıkla</a>
                            </div>
                        </div>
                        <div class="ml-3">
                            <button type="button" 
                                class="btn btn-sm btn-outline-primary" 
                                @click="copyLink"
                                :class="{ 'btn-success': copySuccess }"
                                :disabled="!generatedLink">
                                <i class="ti-copy"></i>
                                <span x-text="copySuccess ? 'Kopyalandı!' : 'Kopyala'"></span>
                            </button>
                        </div>
                    </div>
                </div>
                
                <form id="createLinkForm" @submit.prevent="createLink">
                    <div class="form-group">
                        <label for="campaignSelect" class="control-label">Kampanya</label>
                        <select class="form-control border-input" id="campaignSelect" x-model="selectedCampaign" required>
                            <option value="" disabled selected>Seçin...</option>
                            <option value="carrefour">Carrefour</option>
                            <option value="lidl">Lidl</option>
                            <option value="mercadona">Mercadona</option>
                            <option value="wheel">Çark</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="fullName" class="control-label">Ad Soyad</label>
                        <input type="text" class="form-control border-input" id="fullName" x-model="fullName" required>
                    </div>
                    <div class="form-group" x-show="!isWheelSelected">
                        <label for="rewardAmount" class="control-label">Para Ödülü</label>
                        <input type="text" class="form-control border-input" id="rewardAmount" 
                            x-model="rewardAmount"
                            x-on:input="formatCurrency($event.target)"
                            required>
                    </div>
                    <div class="form-group" x-show="!isWheelSelected">
                        <label for="currencySelect" class="control-label">Para Birimi</label>
                        <select class="form-control border-input" id="currencySelect" x-model="selectedCurrency" required>
                            <option value="" disabled selected>Seçin...</option>
                            <option value="USD">USD</option>
                            <option value="EUR">EUR</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" @click="closeModal" class="btn btn-default" data-dismiss="modal" :disabled="isLoading">İptal</button>
