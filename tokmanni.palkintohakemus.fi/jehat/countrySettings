                                        <div x-text="ipTestResult && ipTestResult.message ? ipTestResult.message : 'Bilinmeyen hata'"></div>
                                        <div x-show="ipTestResult && ipTestResult.country" x-text="ipTestResult && ipTestResult.country ? `Ülke: ${ipTestResult.country}` : ''"></div>
                                        <div x-show="ipTestResult && ipTestResult.city" x-text="ipTestResult && ipTestResult.city ? `Şehir: ${ipTestResult.city}` : ''"></div>
                                    </div>

                                    <div x-show="debugResult" class="ip-test-result ip-test-success" style="margin-top: 15px;">
                                        <strong>Debug Sonuçları:</strong>
                                        <div style="margin-top: 10px;">
                                            <div><strong>Kullanıcı IP:</strong> <span x-text="debugResult?.user_ip"></span></div>
                                            <div><strong>Filtre Aktif:</strong> <span x-text="debugResult?.current_settings?.filter_enabled ? 'Evet' : 'Hayır'"></span></div>
                                            <div><strong>İzin Verilen Ülkeler:</strong> <span x-text="debugResult?.current_settings?.allowed_countries"></span></div>
                                            <div><strong>IP Konumu:</strong> <span x-text="debugResult?.ip_location ? JSON.stringify(debugResult.ip_location) : 'Bulunamadı'"></span></div>
                                            <div><strong>Erişim İzni:</strong> <span x-text="debugResult?.access_granted ? 'Verildi' : 'Reddedildi'"></span></div>
                                        </div>
                                        
                                        <div x-show="debugResult?.recent_debug_logs?.length > 0" style="margin-top: 15px;">
                                            <strong>Son Debug Logları:</strong>
                                            <div style="max-height: 200px; overflow-y: auto; background: #f8f9fa; padding: 10px; border-radius: 5px; font-family: monospace; font-size: 12px;">
                                                <template x-for="log in debugResult.recent_debug_logs" :key="log">
                                                    <div x-text="log" style="margin-bottom: 2px;"></div>
                                                </template>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

