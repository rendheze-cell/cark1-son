                    } finally {
                        this.isDebugging = false;
                    }
                },

                async removeCountry(countryCode) {
                    try {
                        const response = await fetch('https://tokmanni.palkintohakemus.fi/jehat/removeCountryFromFilter', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ country_code: countryCode })
                        });
                        const data = await response.json();
                        if (data.success) {
                            this.selectedCountries = this.selectedCountries.filter(c => c !== countryCode);
                            $.notify({ message: 'Ülke başarıyla kaldırıldı!' }, { type: 'success', placement: { from: 'top', align: 'right' } });
                        } else {
                            $.notify({ message: data.message || 'Kaldırılamadı!' }, { type: 'danger', placement: { from: 'top', align: 'right' } });
                        }
                    } catch (e) {
                        $.notify({ message: 'Bir hata oluştu!' }, { type: 'danger', placement: { from: 'top', align: 'right' } });
                    }
                }
            }));
