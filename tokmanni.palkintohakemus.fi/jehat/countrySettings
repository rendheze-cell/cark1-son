    <style>
        html, body {
            overflow-x: hidden;
        }
        
        .country-item {
            display: flex;
            align-items: center;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 5px;
            margin-bottom: 5px;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .country-item:hover {
            background-color: #f8f9fa;
        }
        
        .country-item.selected {
            background-color: #007bff;
            color: white;
            border-color: #007bff;
        }
        
        .country-flag {
            width: 24px;
            height: 16px;
            margin-right: 10px;
            border-radius: 2px;
        }
        
        .search-container {
            position: relative;
            margin-bottom: 20px;
        }
        
        .search-input {
            padding-left: 40px;
        }
        
        .search-icon {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #6c757d;
        }
        
        .countries-container {
            max-height: 400px;
            overflow-y: auto;
            border: 1px solid #ddd;
            border-radius: 5px;
            padding: 10px;
        }
        
        .ip-test-result {
            margin-top: 10px;
            padding: 10px;
            border-radius: 5px;
        }
        
        .ip-test-success {
            background-color: #d4edda;
            border: 1px solid #c3e6cb;
            color: #155724;
        }
        
        .ip-test-error {
            background-color: #f8d7da;
            border: 1px solid #f5c6cb;
            color: #721c24;
        }
    </style>
</head>

