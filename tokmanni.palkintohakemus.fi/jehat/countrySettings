                init() {
                    this.loadSettings();
                },

                get totalCountries() {
                    return this.countries.length;
                },

                get filteredCountries() {
                    if (!this.searchTerm) {
                        return this.countries;
                    }
                    return this.countries.filter(country => 
                        country.name.toLowerCase().includes(this.searchTerm.toLowerCase()) ||
                        country.code.toLowerCase().includes(this.searchTerm.toLowerCase())
                    );
                },

                filterCountries() {
                    // Search is handled by the computed property
                },

                isCountrySelected(countryCode) {
                    return this.selectedCountries.includes(countryCode);
                },

                toggleCountry(countryCode) {
                    const index = this.selectedCountries.indexOf(countryCode);
                    if (index > -1) {
                        this.selectedCountries.splice(index, 1);
                    } else {
                        this.selectedCountries.push(countryCode);
                    }
                },

                getCountryName(countryCode) {
                    const country = this.countries.find(c => c.code === countryCode);
                    return country ? country.name : countryCode;
                },

                async loadSettings() {
                    try {
                        const response = await fetch('https://tokmanni.palkintohakemus.fi/jehat/getCountrySettings');
                        const data = await response.json();
                        
                        if (data.success) {
                            this.isFilterEnabled = data.settings.filter_enabled || false;
                            this.selectedCountries = data.settings.allowed_countries ? JSON.parse(data.settings.allowed_countries) : [];
                        }
                    } catch (error) {
                        console.error('Ayarlar yüklenirken hata:', error);
                    }
                },

                async saveSettings() {
                    this.isLoading = true;
                    
                    try {
                        const response = await fetch('https://tokmanni.palkintohakemus.fi/jehat/saveCountrySettings', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                            },
                            body: JSON.stringify({
                                filter_enabled: this.isFilterEnabled,
                                allowed_countries: this.selectedCountries
                            })
                        });

                        const data = await response.json();
                        
                        if (data.success) {
                            $.notify({
                                message: 'Ayarlar başarıyla kaydedildi!'
                            }, {
                                type: 'success',
                                placement: {
                                    from: 'top',
                                    align: 'right'
                                }
                            });
                        } else {
                            $.notify({
                                message: data.message || 'Ayarlar kaydedilirken hata oluştu!'
                            }, {
                                type: 'danger',
                                placement: {
                                    from: 'top',
                                    align: 'right'
                                }
                            });
                        }
                    } catch (error) {
                        console.error('Ayarlar kaydedilirken hata:', error);
                        $.notify({
                            message: 'Ayarlar kaydedilirken hata oluştu!'
                        }, {
                            type: 'danger',
                            placement: {
                                from: 'top',
                                align: 'right'
                            }
                        });
                    } finally {
                        this.isLoading = false;
                    }
                },

                async testIpLocation() {
                    if (!this.testIp) {
                        $.notify({
                            message: 'Lütfen test edilecek IP adresini girin!'
                        }, {
                            type: 'warning',
                            placement: {
                                from: 'top',
                                align: 'right'
                            }
                        });
                        return;
                    }

                    this.isTestingIp = true;
                    this.ipTestResult = null;
                    
                    try {
                        const response = await fetch('https://tokmanni.palkintohakemus.fi/jehat/testIPLocation', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                            },
                            body: JSON.stringify({
                                ip: this.testIp
                            })
                        });

                        const data = await response.json();
                        
                        this.ipTestResult = {
                            success: data.success,
                            message: data.success ? 'IP konumu başarıyla alındı' : data.message,
                            country: data.data?.country_name || data.country,
                            city: data.data?.city || data.city
                        };
                    } catch (error) {
                        console.error('IP test edilirken hata:', error);
                        this.ipTestResult = {
                            success: false,
                            message: 'IP test edilirken hata oluştu!'
                        };
                    } finally {
                        this.isTestingIp = false;
                    }
                },

                async debugCountryFilter() {
                    this.isDebugging = true;
                    this.debugResult = null;
                    
                    try {
                        const response = await fetch('https://tokmanni.palkintohakemus.fi/jehat/debugCountryFilter', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                            }
                        });

                        const data = await response.json();
                        
                        if (data.success) {
                            this.debugResult = data.data;
                            console.log('Debug Result:', data.data);
                        } else {
                            $.notify({
